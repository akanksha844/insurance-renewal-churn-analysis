      <aliases enabled='yes' />
      <column caption='Age group' datatype='string' name='[Age_group]' role='dimension' type='nominal' />
      <column caption='Total Customers' datatype='integer' name='[Calculation_1814194372976640]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([customer_id])' />
      </column>
      <column caption='Total Churn' datatype='integer' name='[Calculation_1814194378448902]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;if [renewed]= &apos;Churn&apos; THEN 1 ELSE 0 END&#13;&#10;)' />
      </column>
      <column caption='Churn Rate' datatype='real' name='[Calculation_1814194380189703]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1814194378448902]/[Calculation_1814194372976640]' />
      </column>
      <column caption='Churn probability' datatype='real' name='[Calculation_1814194386735112]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([churn_flag])' />
      </column>
      <column caption='Total customers' datatype='integer' name='[Calculation_1814194387726345]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([customer_id])' />
      </column>
      <column caption='Policy churn%' datatype='real' name='[Calculation_1814194392719370]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1814194378448902]/[Calculation_1814194387726345]' />
      </column>
      <column caption='Risk segment' datatype='string' name='[Calculation_1814194395762699]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1814194386735112] &gt;= 0.7 THEN &quot;High Risk&quot;&#13;&#10;ELSEIF [Calculation_1814194386735112] &gt;= 0.4 THEN &quot;Medium Risk&quot;&#13;&#10;ELSE &quot;Low Risk&quot;&#13;&#10;END' />
      </column>
      <column caption='Expiring Soon' datatype='integer' name='[Calculation_1814194405306381]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF DATEDIFF(&apos;day&apos;, TODAY(), [expiry_date]) &lt;= 30 THEN &#13;&#10;1 ELSE 0 END' />
      </column>
      <column caption='Payment Pending' datatype='integer' name='[Calculation_1814194405543950]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [payment_status] = &quot;Pending&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Renewed metric' datatype='integer' name='[Calculation_1814194405703695]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [renewed] = &quot;Retention%&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Churned metric' datatype='integer' name='[Calculation_1814194405847056]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [renewed] = &quot;Churn%&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='Funnel Stage' datatype='string' name='[Calculation_1814194406010897]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Total Customers&quot;' />
      </column>
      <column caption='Premium group' datatype='string' name='[Premium_group]' role='dimension' type='nominal' />
